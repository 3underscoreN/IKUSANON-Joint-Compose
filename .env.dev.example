# copy to .env.dev
NODE_ENV=development

# PostgreSQL database credentials
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=ikusanon_boostday_form_dev

# Database connection URL
DATABASE_URL=postgresql://postgres:postgres@postgres:5432/ikusanon_boostday_form_dev

# Discord Bot Configuration
DISCORD_TOKEN=

# SEGA Parser Credentials
PARSER_SEGA_ID=
PARSER_SEGA_PW=

# Web URLs - used by bot for links and API calls
# This is for the links the bot sends to users
WEB_URL_BASE=http://localhost:3000

# This is the underlying API URL the bot uses to fetch data
WEB_API_URL_BASE=http://web:3000

# Discord Bot Owner ID (optional)
BOT_OWNER=

